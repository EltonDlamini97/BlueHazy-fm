{
  "installCommand": "npm install -g pnpm@11.1.1 && pnpm install --ignore-scripts --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/bluehazy-fm run build",
  "outputDirectory": "artifacts/bluehazy-fm/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://bluehazy-fm-api.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
