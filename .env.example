# ── Supabase Postgres (required for API) ─────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string → URI
# Use "Transaction" pooler (port 6543) for server apps, or direct (5432).
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── API server (local dev) ───────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Supabase Storage (optional — public image URLs in seed/admin) ───────────
SUPABASE_URL=https://jcujkjznziksxxgwirfb.supabase.co
SUPABASE_STORAGE_BUCKET=bluehazy-fm

# ── Zeno.fm metadata (optional — mount id from Broadcast settings) ───────────
ZENO_MOUNT_ID=fyhks2vxdmgvv

# ── Radio stream (optional — frontend .env.local) ───────────────────────────
# VITE_RADIO_STREAM_URL=https://stream.zeno.fm/fyhks2vxdmgvv
