{
  "buildCommand": "cd ../.. && pnpm install --ignore-scripts && pnpm --filter @workspace/bluehazy-fm run build",
  "outputDirectory": "dist/public",
  "installCommand": "echo 'install handled by buildCommand'",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://bluehazy-fm-api.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
